# truemtls serve configuration (copied to ~/.config/truemtls/truemtls.env by
# `task install-unit`). Edit, then: systemctl --user start truemtls

# Backend to put behind mandatory mTLS (plain HTTP, same host).
BACKEND=http://127.0.0.1:8080

# Address truemtls listens on (mTLS). Use 0.0.0.0 to accept LAN clients.
LISTEN=0.0.0.0:8443

# To trust a CA, drop its PEM into ~/.config/truemtls/trust/authorities/
# (or approve on first connect: `truemtls trust approve authority <fp>`).
